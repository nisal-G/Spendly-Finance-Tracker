<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <!-- Background color -->
    <solid android:color="@color/soft_lavender" />

    <!-- Optional: Add a slight elevation effect with a stroke -->
    <stroke
        android:width="1dp"
        android:color="#20000000" />

    <!-- Optional: Size configuration -->
    <size
        android:width="40dp"
        android:height="40dp" />
</shape>